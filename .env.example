# App
APP_NAME=Velocity
APP_ENV=development
APP_URL=http://localhost:4000
APP_PORT=4000
# CORS: comma-separated origins allowed to make credentialed cross-origin
# requests. NEVER use "*" with credentials. Defaults to APP_URL when unset.
CORS_ALLOWED_ORIGINS=http://localhost:4000

# Logging
LOG_DRIVER=console
LOG_LEVEL=info

# Encryption & signing - the installer populates these with random
# 32-byte base64 values at install time. APP_KEY is also the crypto
# fallback; set CRYPTO_KEY explicitly only if you want a dedicated
# crypto key separate from APP_KEY.
#
# APP_KEY MUST carry the "base64:" prefix so velocity/crypto base64-
# decodes it back to the 32 raw bytes the AES driver requires. Use
# `vel key:generate` to (re)mint it; pasting a raw base64 value
# without the prefix will fail boot with ErrInvalidKeyLength.
# QUEUE_SIGNING_KEY and AUTH_JWT_SECRET are consumed as raw HMAC
# bytes and stay unprefixed.
APP_KEY=
QUEUE_SIGNING_KEY=
AUTH_JWT_SECRET=
CRYPTO_CIPHER=AES-256-CBC

# Enable to revoke blacklisted JWT IDs.
AUTH_JWT_BLACKLIST_ENABLED=false
# AUTH_JWT_ALGO=HS256

# Database
DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=database.sqlite
DB_USERNAME=
DB_PASSWORD=
# DB_CHARSET=utf8mb4
# DB_SSL_MODE=disable
# DB_LOG_QUERIES=false
# DB_SLOW_QUERY_THRESHOLD=100
# DB_MAX_OPEN_CONNS=25
# DB_MAX_IDLE_CONNS=5
# DB_CONN_MAX_LIFETIME=300

# Cache
CACHE_DRIVER=memory
# CACHE_PREFIX=velocity_
# CACHE_PATH=storage/cache

# Session
SESSION_NAME=velocity_session
SESSION_LIFETIME=120
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# CSRF
# CSRF_TOKEN_LIFETIME=24h
# CSRF_HEADER=X-CSRF-Token
# CSRF_FORM_FIELD=_token
# CSRF_COOKIE_NAME=csrf_token
# CSRF_SECURE=true
# CSRF_HTTP_ONLY=true
# CSRF_SAME_SITE=lax
# CSRF_SINGLE_USE=false

# Authentication
AUTH_GUARD=web
AUTH_MODEL=User

# Hashing
# HASH_BCRYPT_COST=12

# Queue
# QUEUE_DRIVER=sync
# QUEUE_REDIS_HOST=127.0.0.1
# QUEUE_REDIS_PORT=6379
# QUEUE_REDIS_PASSWORD=
# QUEUE_REDIS_DB=0

# Redis
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DATABASE=0

# Mail
# MAIL_DRIVER=smtp
# MAIL_HOST=smtp.mailtrap.io
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=hello@example.com
# MAIL_FROM_NAME="${APP_NAME}"

# Mailgun
# MAIL_MAILGUN_DOMAIN=
# MAIL_MAILGUN_SECRET=
# MAIL_MAILGUN_ENDPOINT=api.mailgun.net
# MAIL_MAILGUN_WEBHOOK_SIGNING_KEY=

# Postmark
# MAIL_POSTMARK_TOKEN=
# MAIL_POSTMARK_MESSAGE_STREAM=outbound

# AWS / S3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_URL=
# AWS_VISIBILITY=private

# Filesystem
FILESYSTEM_DISK=local
# FILESYSTEM_LOCAL_ROOT=storage/app
# FILESYSTEM_LOCAL_URL=/storage
# FILESYSTEM_LOCAL_VISIBILITY=private
# FILESYSTEM_PUBLIC_ROOT=storage/app/public
# FILESYSTEM_PUBLIC_URL=/storage

# gRPC (optional, only used when grpc.NewServer is wired in main.go)
# GRPC_PORT=50051
# GRPC_REFLECTION=false
# GRPC_MAX_RECV_SIZE=4194304
# GRPC_MAX_SEND_SIZE=4194304

# gRPC Gateway (HTTP/JSON to gRPC bridge)
# GATEWAY_PORT=8080
# GRPC_ENDPOINT=localhost:50051

# JWT tuning (secret + blacklist flag live at the top of this file).
# AUTH_JWT_TTL=60
# AUTH_JWT_REFRESH_TTL=20160

# View SSR (Inertia)
# Point VIEW_SSR_URL at Vite in development (http://localhost:5173/__inertia_ssr)
# or at a running Node SSR bundle in production (http://127.0.0.1:13714/render).
# VIEW_SSR_ENABLED=false
# VIEW_SSR_URL=http://127.0.0.1:13714/render
# VIEW_SSR_TIMEOUT=3s
# VIEW_SSR_EXCEPT=/admin,/internal
